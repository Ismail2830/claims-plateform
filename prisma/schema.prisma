// ─── ChatSession / ChatMessage ───────────────────────────────────────────────

model ChatSession {
  id                String     @id @default(uuid()) @db.Uuid
  clientId          String     @map("client_id") @db.Uuid
  status            ChatStatus @default(ACTIVE)
  claimType         String?    @map("claim_type")
  currentStep       String     @default("START") @map("current_step")
  context           Json       @default("{}")
  createdClaimId    String?    @map("created_claim_id") @db.Uuid
  declarationMethod String     @default("CHATBOT") @map("declaration_method")
  language          String     @default("fr")
  completedAt       DateTime?  @map("completed_at")
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")

  messages ChatMessage[]
  client   Client        @relation(fields: [clientId], references: [clientId])

  @@index([clientId], map: "idx_chat_sessions_client")
  @@index([status], map: "idx_chat_sessions_status")
  @@map("chat_sessions")
}

model ChatMessage {
  id        String      @id @default(uuid()) @db.Uuid
  sessionId String      @map("session_id") @db.Uuid
  role      MessageRole
  content   String      @db.Text
  metadata  Json?
  createdAt DateTime    @default(now()) @map("created_at")

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId], map: "idx_chat_messages_session")
  @@index([createdAt], map: "idx_chat_messages_date")
  @@map("chat_messages")
}

// ─── Chatbot enums ────────────────────────────────────────────────────────────

enum ChatStatus {
  ACTIVE
  COMPLETED
  ABANDONED
  TRANSFERRED_TO_AGENT
}

enum MessageRole {
  USER
  BOT
  SYSTEM
}

// ─── Offline Payment ──────────────────────────────────────────────────────────

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CHECK
  MOBILE_MONEY
}

model ClaimPayment {
  paymentId    String        @id @default(uuid()) @map("payment_id") @db.Uuid
  claimId      String        @unique @map("claim_id") @db.Uuid
  amount       Decimal       @db.Decimal(12, 2)
  method       PaymentMethod
  reference    String?       @db.VarChar(150)
  paidAt       DateTime      @map("paid_at")
  recordedBy   String        @map("recorded_by") @db.Uuid
  notes        String?       @db.Text
  createdAt    DateTime      @default(now()) @map("created_at")

  claim        Claim         @relation(fields: [claimId], references: [claimId], onDelete: Cascade)
  recordedByUser User        @relation("PaymentRecordedBy", fields: [recordedBy], references: [userId])

  @@index([claimId], map: "idx_claim_payments_claim")
  @@map("claim_payments")
}
